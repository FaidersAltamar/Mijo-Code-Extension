{
	"name": "mijo-code",
	"displayName": "Mijo Code",
	"description": "Chat con agente de codificación con IA dentro de VS Code",
	"version": "0.0.9",
	"publisher": "MijoCodeExtension",
	"license": "MIT",
	"icon": "media/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/FaidersAltamar/Mijo-Code-Extension.git"
	},
	"bugs": {
		"url": "https://github.com/FaidersAltamar/Mijo-Code-Extension/issues"
	},
	"homepage": "https://github.com/FaidersAltamar/Mijo-Code-Extension",
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"AI",
		"Chat",
		"Programming Languages"
	],
	"keywords": [
		"ai",
		"agent",
		"chat",
		"copilot",
		"assistant"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCommand:ocursor.openChat",
		"onCommand:ocursor.addToChat",
		"onCommand:ocursor.openSettings"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ocursor.openSettings",
				"title": "Abrir configuración de Mijo Code"
			},
			{
				"command": "ocursor.openChat",
				"title": "Abrir chat de Mijo Code",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "ocursor.addToChat",
				"title": "Mijo Code: Añadir selección al chat"
			}
		],
		"keybindings": [
			{
				"command": "ocursor.openChat",
				"key": "ctrl+alt+m",
				"mac": "cmd+alt+m"
			},
			{
				"command": "ocursor.addToChat",
				"key": "ctrl+l",
				"mac": "cmd+l",
				"when": "editorTextFocus"
			}
		],
		"configuration": [
			{
				"title": "Configuración de Mijo Code",
				"properties": {
					"ocursor.model": {
						"type": "string",
						"default": "auto",
						"description": "El modelo de IA a usar"
					},
					"ocursor.maxResponseLength": {
						"type": "integer",
						"default": 0,
						"description": "Longitud máxima de respuesta en tokens (0 = dejar que el modelo decida)"
					},
					"ocursor.maxContextTokens": {
						"type": "integer",
						"default": 262144,
						"minimum": 1024,
						"description": "Límite máximo de tokens de contexto usados para construir las peticiones (evita exceder el límite del proveedor)"
					},
					"ocursor.enableWorkspaceContext": {
						"type": "boolean",
						"default": true,
						"description": "Habilitar contexto del workspace para el agente de IA"
					},
					"ocursor.enableFileReading": {
						"type": "boolean",
						"default": true,
						"description": "Habilitar herramientas de lectura/glob/búsqueda de archivos"
					},
					"ocursor.enableTerminalSuggestions": {
						"type": "boolean",
						"default": true,
						"description": "Habilitar herramienta de sugerencias de comandos de terminal"
					},
					"ocursor.systemPrompt": {
						"type": "string",
						"default": "You are a professional coding assistant extension named Mijo Code.",
						"description": "Campo de instrucción personalizada o system prompt"
					},
					"ocursor.language": {
						"type": "string",
						"default": "es",
						"enum": ["en", "es"],
						"enumDescriptions": ["English", "Español"],
						"description": "Idioma de la interfaz de la extensión"
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "pnpm run package",
		"compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
		"check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.webview.json",
		"lint": "eslint src",
		"test": "vscode-test",
		"vsix": "pnpm run package && pnpm dlx @vscode/vsce package --no-dependencies"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "24.x",
		"@types/pdf-parse": "^1.1.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/vscode": "^1.105.0",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^3.0.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"npm-run-all": "^4.1.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1"
	},
	"overrides": {
		"diff": "^8.0.4",
		"serialize-javascript": "^7.0.6"
	},
	"dependencies": {
		"@huggingface/hub": "^2.13.2",
		"@huggingface/transformers": "^4.2.0",
		"lucide-react": "^1.21.0",
		"marked": "^18.0.5",
		"onnxruntime-node": "^1.27.0",
		"pdf-parse": "^2.4.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"sharp": "^0.35.2"
	},
	"vsce": {
		"dependencies": false
	}
}
